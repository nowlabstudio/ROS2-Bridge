{
    "app_setting": {
        "window_size": [1600, 900],
        "font": "/usr/share/fonts/truetype/ubuntu/Ubuntu-C.ttf",
        "ignore_unconnected_nodes": false,
        "ignore_node_list": [
            "/_ros2cli.*",
            "/rqt.*"
        ],
        "ignore_topic_list": [
            "/rosout",
            "/tf",
            "/tf_static",
            "/parameter_events",
            "/clock"
        ]
    },
    "group_setting": {
        "/robot": {
            "direction": "horizontal",
            "offset": [0.0, 0.0, 4.0, 3.0],
            "color": [0, 100, 160]
        },
        "__others__": {
            "direction": "horizontal",
            "offset": [0.0, 3.5, 4.0, 2.0],
            "color": [60, 80, 60]
        }
    }
}
