        "data_bits": 8,
        "parity": "none",
        "stop_bits": 1
      },
      "publish": {
        "topic": "uart_sensor/data",
        "msg_type": "std_msgs/String",
        "freq_ms": 100
      },
      "subscribe": {
        "topic": "uart_sensor/cmd",
        "msg_type": "std_msgs/String"
      }
    },

    {
      "id": 7,
