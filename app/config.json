  "channels": [

    {
      "id": 0,
      "name": "motor_left",
      "type": "motor_encoder",
      "enabled": true,
      "hw": {
        "pwm_pin": 2,
        "dir_pin": 3,
        "encoder_pio": 0,
        "encoder_pin_a": 10,
        "encoder_pin_b": 11
      },
      "pid": {
        "enabled": true,
        "kp": 1.2,
        "ki": 0.05,
        "kd": 0.01,
        "output_min": -100.0,
        "output_max": 100.0
      },
      "publish": {
        "topic": "motor_left/encoder",
        "msg_type": "std_msgs/Float32",
        "freq_ms": 10
      },
      "subscribe": {
        "topic": "motor_left/setpoint",
        "msg_type": "std_msgs/Float32"
      }
    },

    {
      "id": 1,
      "name": "motor_right",
      "type": "motor_encoder",
      "enabled": true,
      "hw": {
        "pwm_pin": 4,
        "dir_pin": 5,
        "encoder_pio": 1,
        "encoder_pin_a": 12,
        "encoder_pin_b": 13
      },
      "pid": {
        "enabled": true,
        "kp": 1.2,
        "ki": 0.05,
        "kd": 0.01,
        "output_min": -100.0,
        "output_max": 100.0
      },
      "publish": {
        "topic": "motor_right/encoder",
        "msg_type": "std_msgs/Float32",
