      "publish": {
        "topic": "gpio_relay/state",
        "msg_type": "std_msgs/Bool",
        "freq_ms": 500
      },
      "subscribe": {
        "topic": "gpio_relay/cmd",
        "msg_type": "std_msgs/Bool"
      }
    },

    {
      "id": 4,
      "name": "gpio_button",
      "type": "gpio",
      "enabled": true,
      "hw": {
        "pin": 17,
        "direction": "input",
        "pull": "up"
      },
      "publish": {
        "topic": "gpio_button/state",
        "msg_type": "std_msgs/Bool",
        "freq_ms": 50
      },
      "subscribe": {
        "enabled": false
      }
    },

    {
      "id": 5,
      "name": "adc_distance",
      "type": "adc",
      "enabled": true,
      "hw": {
        "pin": 26,
