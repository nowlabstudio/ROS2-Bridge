    {
      "id": 2,
      "name": "servo_tilt",
      "type": "servo",
      "enabled": true,
      "hw": {
        "pwm_pin": 6,
        "pwm_min_us": 1000,
        "pwm_max_us": 2000
      },
      "publish": {
        "topic": "servo_tilt/position_fb",
        "msg_type": "std_msgs/Float32",
        "freq_ms": 50
      },
      "subscribe": {
        "topic": "servo_tilt/position",
        "msg_type": "std_msgs/Float32"
      }
    },

    {
      "id": 3,
      "name": "gpio_relay",
