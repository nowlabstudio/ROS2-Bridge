        "vref": 3.3,
        "scale": 1.0,
        "offset": 0.0
      },
      "publish": {
        "topic": "adc_distance/voltage",
        "msg_type": "std_msgs/Float32",
        "freq_ms": 20
      },
      "subscribe": {
        "enabled": false
      }
    },

    {
