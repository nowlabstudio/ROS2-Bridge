/ {
	chosen {
		zephyr,console = &cdc_acm_uart0;
		zephyr,shell-uart = &cdc_acm_uart0;
	};

	/*
	 * ADC csatorna — akkumulátor feszültség mérés
	 * Placeholder: GP26 = ADC0. Hardver véglegesítésekor csak a channel
	 * számot kell átírni (0=GP26, 1=GP27, 2=GP28, 3=GP29/VSYS).
	 */
	zephyr,user {
		io-channels = <&adc 0>;
	};

	leds {
		compatible = "gpio-leds";
		user_led: led_0 {
			gpios = <&gpio0 25 GPIO_ACTIVE_HIGH>;
			label = "User LED (GP25)";
		};
	};

	/*
	 * GPIO csatornák — placeholder pinek, hardver véglegesítésekor
	 * csak az alábbi GP számokat kell átírni, C kód nem változik.
	 *
	 * estop-btn:   GP27 — E-Stop NC gomb (GND felé kötve, pull-up)
	 * relay-brake: GP14 — Fékvezérlő relé kimenet
	 */
	gpio_channels {
		compatible = "gpio-keys";

		estop_btn: estop_btn {
			gpios = <&gpio0 27 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
			label = "E-Stop button (NC)";
		};

		relay_brake: relay_brake {
			gpios = <&gpio0 14 GPIO_ACTIVE_HIGH>;
			label = "Brake relay output";
		};
	};

	rc_inputs {
		compatible = "gpio-keys";

		rc_ch1: rc_ch1 { gpios = <&gpio0 2 0>; label = "RC CH1 (GP2)"; };
		rc_ch2: rc_ch2 { gpios = <&gpio0 3 0>; label = "RC CH2 (GP3)"; };
		rc_ch3: rc_ch3 { gpios = <&gpio0 4 0>; label = "RC CH3 (GP4)"; };
		rc_ch4: rc_ch4 { gpios = <&gpio0 5 0>; label = "RC CH4 (GP5)"; };
		rc_ch5: rc_ch5 { gpios = <&gpio0 6 0>; label = "RC CH5 (GP6)"; };
		rc_ch6: rc_ch6 { gpios = <&gpio0 7 0>; label = "RC CH6 (GP7)"; };
	};

	aliases {
		led0        = &user_led;
		estop-btn   = &estop_btn;
		relay-brake = &relay_brake;
		rc-ch1      = &rc_ch1;
		rc-ch2      = &rc_ch2;
		rc-ch3      = &rc_ch3;
		rc-ch4      = &rc_ch4;
		rc-ch5      = &rc_ch5;
		rc-ch6      = &rc_ch6;
	};
};

&zephyr_udc0 {
	cdc_acm_uart0: cdc_acm_uart0 {
		compatible = "zephyr,cdc-acm-uart";
	};
};

/*
 * Board hardware contains a WIZnet W6100 chip, de W5500-kompatibilis módban
 * vezéreljük (csak IPv4 UDP kell). A stock `w5500_evb_pico` board def a
 * wiznet,w5500 drivert köti a &ethernet node-hoz — a felülírást eltávolítottuk.
 * Ha egyszer W6100-specifikus feature (IPv6, hardveres SSL/TLS) kellene,
 * akkor cserélendő vissza compatible = "wiznet,w6100"-ra + CONFIG_ETH_W6100.
 */

/* ADC — akkumulátor feszültség (GP26 = channel 0, placeholder) */
&adc {
	#address-cells = <1>;
	#size-cells = <0>;
	status = "okay";

	channel@0 {
		reg = <0>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};
};

/* LittleFS storage partition — last 1MB of flash (offset 15MB) */
&flash0 {
	partitions {
		storage_partition: partition@f00000 {
			label = "storage";
			reg = <0x00f00000 0x00100000>;
		};
	};
};
