/*
 * apps/rc/boards/w5500_evb_pico.overlay — RC-only board overlay.
 *
 * Pin-kiosztás:
 *   - rc_ch1..6   GP2..GP7  — PWM input
 *                             * IRQ-fallback driver (drv_pwm_in.c):
 *                               a pineket a `rc_inputs` gpio-keys blokk
 *                               adja GPIO_PULL_DOWN flaggel.
 *                             * PIO driver (drv_pwm_in_pio.c, BL-020 Step 2):
 *                               a pinek PIO funkcióra váltanak a
 *                               pinctrl-0 groupok aktiválásakor; a
 *                               `&pio0 / &pio1` child node-ok adják a
 *                               csatorna-metszeteket.
 *   - gp8..gp11   GP8..GP11 — generic Bool output + pin-readback feedback
 *                             (ACTIVE_HIGH, cmd sub + state pub csatornák;
 *                              GP8 fizikailag világítás-relét hajt, a többi
 *                              még szabad — bármilyen relé/LED bedrótozható).
 *   - user_led    GP25      — bridge-online indikátor (common/src/main.c)
 *
 * A per-device overlay csak az RC funkciókhoz szükséges pineket deklarálja —
 * más device-ok (E_STOP, PEDAL) pinkiosztása független, így ugyanaz a pin
 * egy másik app-ban más szerepet kaphat (pl. GP22 E_STOP okgo_led).
 *
 * Ethernet: a board default w5500-ot köt a &ethernet node-ra, itt
 * felülírjuk W6100-ra (out-of-tree driver: modules/w6100_driver/).
 *
 * LittleFS: a config.json perzisztens tárolása a flash utolsó 1 MB-jában
 * (offset 15 MB) — szükséges a `bridge config` shell parancsokhoz.
 */

/ {
	chosen {
		zephyr,console = &cdc_acm_uart0;
		zephyr,shell-uart = &cdc_acm_uart0;
	};

	leds {
		compatible = "gpio-leds";
		user_led: led_0 {
			gpios = <&gpio0 25 GPIO_ACTIVE_HIGH>;
			label = "User LED (GP25)";
		};
		gp8_out: gp8_out {
			gpios = <&gpio0 8 GPIO_ACTIVE_HIGH>;
			label = "GP8 generic output (lights relay)";
		};
		gp9_out: gp9_out {
			gpios = <&gpio0 9 GPIO_ACTIVE_HIGH>;
			label = "GP9 generic output";
		};
		gp10_out: gp10_out {
			gpios = <&gpio0 10 GPIO_ACTIVE_HIGH>;
			label = "GP10 generic output";
		};
		gp11_out: gp11_out {
			gpios = <&gpio0 11 GPIO_ACTIVE_HIGH>;
			label = "GP11 generic output";
		};
	};

	rc_inputs {
		compatible = "gpio-keys";

		rc_ch1: rc_ch1 { gpios = <&gpio0 2 GPIO_PULL_DOWN>; label = "RC CH1 (GP2)"; };
		rc_ch2: rc_ch2 { gpios = <&gpio0 3 GPIO_PULL_DOWN>; label = "RC CH2 (GP3)"; };
		rc_ch3: rc_ch3 { gpios = <&gpio0 4 GPIO_PULL_DOWN>; label = "RC CH3 (GP4)"; };
		rc_ch4: rc_ch4 { gpios = <&gpio0 5 GPIO_PULL_DOWN>; label = "RC CH4 (GP5)"; };
		rc_ch5: rc_ch5 { gpios = <&gpio0 6 GPIO_PULL_DOWN>; label = "RC CH5 (GP6)"; };
		rc_ch6: rc_ch6 { gpios = <&gpio0 7 GPIO_PULL_DOWN>; label = "RC CH6 (GP7)"; };
	};

	aliases {
		led0    = &user_led;
		rc-ch1  = &rc_ch1;
		rc-ch2  = &rc_ch2;
		rc-ch3  = &rc_ch3;
		rc-ch4  = &rc_ch4;
		rc-ch5  = &rc_ch5;
		rc-ch6  = &rc_ch6;
		gp8-out  = &gp8_out;
		gp9-out  = &gp9_out;
		gp10-out = &gp10_out;
		gp11-out = &gp11_out;
	};
};

&zephyr_udc0 {
	cdc_acm_uart0: cdc_acm_uart0 {
		compatible = "zephyr,cdc-acm-uart";
	};
};

&ethernet {
	compatible = "wiznet,w6100";
};

/* LittleFS storage partition — last 1MB of flash (offset 15MB) */
&flash0 {
	partitions {
		storage_partition: partition@f00000 {
			label = "storage";
			reg = <0x00f00000 0x00100000>;
		};
	};
};

/*
 * ─────────────────────────────────────────────────────────────────────────
 * BL-020 Step 2 — PIO-alapú PWM input capture (IRQ-mentes, deterministic).
 *
 * A 6 RC csatornát 6 külön PIO state machine méri: CH1..CH4 a PIO0-n, CH5..CH6
 * a PIO1-en. Minden csatorna saját `nowlab,pwm-input-pio` child node-ot kap
 * egy-egy dedikált pinctrl group-pal, így a driver (drv_pwm_in_pio.c) minden
 * instance-hez külön tudja allokálni az SM-et és alkalmazni a pinmux-ot.
 *
 * A pinctrl groupok `input-enable` + `bias-pull-down` párost kapnak, hogy:
 *   - az RC vevő kihúzásakor a pin ne lebegjen (ISR-storm elkerülése
 *     továbbra is ugyanúgy fontos, mint a fallback IRQ driveren), és
 *   - a PIO program `wait pin 0/1` utasításai valid logikai szintet lássanak.
 *
 * A meglévő `rc_inputs { compatible = "gpio-keys" }` blokkot és a `rc-ch*`
 * aliasokat fentebb meghagytuk: a fallback IRQ driver (drv_pwm_in.c) és a
 * per-device user_channels.c onnan olvassa ki a GP-számot a
 * `GPIO_DT_SPEC_GET(DT_ALIAS(rc_ch1), gpios)` makróval. A PIO driver a
 * `pin = <N>` property-t használja, a fallback driver a DT_ALIAS spec.pin-t —
 * a két nézet ugyanarra a fizikai GP-re mutat, két szabványos DT mechanizmussal.
 *
 * A pinctrl override a PIO driver init-jekor veszi át a pad funkcióját SIO-ról
 * PIO-ra; a fallback (IRQ) buildben ezek a groupok deklaráltak, de nem
 * aktivizálódnak (mert sem `&pio0`, sem `&pio1` nem `status = okay`).
 * Ha a build a fallback IRQ drivert használja, a `&pio0 {status = "okay"}`
 * és `&pio1 {status = "okay"}` sor akkor is bent maradhat — üres aktív PIO
 * node nem foglal SM-et, amíg nincs benne aktiv child.
 * ─────────────────────────────────────────────────────────────────────────
 */

&pinctrl {
	pio0_pwm_in_ch1_default: pio0_pwm_in_ch1_default {
		group1 {
			pinmux = <PIO0_P2>;
			input-enable;
			bias-pull-down;
		};
	};

	pio0_pwm_in_ch2_default: pio0_pwm_in_ch2_default {
		group1 {
			pinmux = <PIO0_P3>;
			input-enable;
			bias-pull-down;
		};
	};

	pio0_pwm_in_ch3_default: pio0_pwm_in_ch3_default {
		group1 {
			pinmux = <PIO0_P4>;
			input-enable;
			bias-pull-down;
		};
	};

	pio0_pwm_in_ch4_default: pio0_pwm_in_ch4_default {
		group1 {
			pinmux = <PIO0_P5>;
			input-enable;
			bias-pull-down;
		};
	};

	pio1_pwm_in_ch5_default: pio1_pwm_in_ch5_default {
		group1 {
			pinmux = <PIO1_P6>;
			input-enable;
			bias-pull-down;
		};
	};

	pio1_pwm_in_ch6_default: pio1_pwm_in_ch6_default {
		group1 {
			pinmux = <PIO1_P7>;
			input-enable;
			bias-pull-down;
		};
	};
};

&pio0 {
	status = "okay";

	pwm_in_ch1: pwm_in_ch1 {
		compatible = "nowlab,pwm-input-pio";
		status = "okay";
		pin = <2>;
		pinctrl-0 = <&pio0_pwm_in_ch1_default>;
		pinctrl-names = "default";
	};

	pwm_in_ch2: pwm_in_ch2 {
		compatible = "nowlab,pwm-input-pio";
		status = "okay";
		pin = <3>;
		pinctrl-0 = <&pio0_pwm_in_ch2_default>;
		pinctrl-names = "default";
	};

	pwm_in_ch3: pwm_in_ch3 {
		compatible = "nowlab,pwm-input-pio";
		status = "okay";
		pin = <4>;
		pinctrl-0 = <&pio0_pwm_in_ch3_default>;
		pinctrl-names = "default";
	};

	pwm_in_ch4: pwm_in_ch4 {
		compatible = "nowlab,pwm-input-pio";
		status = "okay";
		pin = <5>;
		pinctrl-0 = <&pio0_pwm_in_ch4_default>;
		pinctrl-names = "default";
	};
};

&pio1 {
	status = "okay";

	pwm_in_ch5: pwm_in_ch5 {
		compatible = "nowlab,pwm-input-pio";
		status = "okay";
		pin = <6>;
		pinctrl-0 = <&pio1_pwm_in_ch5_default>;
		pinctrl-names = "default";
	};

	pwm_in_ch6: pwm_in_ch6 {
		compatible = "nowlab,pwm-input-pio";
		status = "okay";
		pin = <7>;
		pinctrl-0 = <&pio1_pwm_in_ch6_default>;
		pinctrl-names = "default";
	};
};
