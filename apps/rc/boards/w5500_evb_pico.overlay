/*
 * apps/rc/boards/w5500_evb_pico.overlay — RC-only board overlay.
 *
 * Pin-kiosztás:
 *   - rc_ch1..6   GP2..GP7  — PWM input (edge-both IRQ a drv_pwm_in-ben)
 *   - gp8..gp11   GP8..GP11 — generic Bool output + pin-readback feedback
 *                             (ACTIVE_HIGH, cmd sub + state pub csatornák;
 *                              GP8 fizikailag világítás-relét hajt, a többi
 *                              még szabad — bármilyen relé/LED bedrótozható).
 *   - user_led    GP25      — bridge-online indikátor (common/src/main.c)
 *
 * A per-device overlay csak az RC funkciókhoz szükséges pineket deklarálja —
 * más device-ok (E_STOP, PEDAL) pinkiosztása független, így ugyanaz a pin
 * egy másik app-ban más szerepet kaphat (pl. GP22 E_STOP okgo_led).
 *
 * Ethernet: a board default w5500-ot köt a &ethernet node-ra, itt
 * felülírjuk W6100-ra (out-of-tree driver: modules/w6100_driver/).
 *
 * LittleFS: a config.json perzisztens tárolása a flash utolsó 1 MB-jában
 * (offset 15 MB) — szükséges a `bridge config` shell parancsokhoz.
 */

/ {
	chosen {
		zephyr,console = &cdc_acm_uart0;
		zephyr,shell-uart = &cdc_acm_uart0;
	};

	leds {
		compatible = "gpio-leds";
		user_led: led_0 {
			gpios = <&gpio0 25 GPIO_ACTIVE_HIGH>;
			label = "User LED (GP25)";
		};
		gp8_out: gp8_out {
			gpios = <&gpio0 8 GPIO_ACTIVE_HIGH>;
			label = "GP8 generic output (lights relay)";
		};
		gp9_out: gp9_out {
			gpios = <&gpio0 9 GPIO_ACTIVE_HIGH>;
			label = "GP9 generic output";
		};
		gp10_out: gp10_out {
			gpios = <&gpio0 10 GPIO_ACTIVE_HIGH>;
			label = "GP10 generic output";
		};
		gp11_out: gp11_out {
			gpios = <&gpio0 11 GPIO_ACTIVE_HIGH>;
			label = "GP11 generic output";
		};
	};

	rc_inputs {
		compatible = "gpio-keys";

		rc_ch1: rc_ch1 { gpios = <&gpio0 2 0>; label = "RC CH1 (GP2)"; };
		rc_ch2: rc_ch2 { gpios = <&gpio0 3 0>; label = "RC CH2 (GP3)"; };
		rc_ch3: rc_ch3 { gpios = <&gpio0 4 0>; label = "RC CH3 (GP4)"; };
		rc_ch4: rc_ch4 { gpios = <&gpio0 5 0>; label = "RC CH4 (GP5)"; };
		rc_ch5: rc_ch5 { gpios = <&gpio0 6 0>; label = "RC CH5 (GP6)"; };
		rc_ch6: rc_ch6 { gpios = <&gpio0 7 0>; label = "RC CH6 (GP7)"; };
	};

	aliases {
		led0    = &user_led;
		rc-ch1  = &rc_ch1;
		rc-ch2  = &rc_ch2;
		rc-ch3  = &rc_ch3;
		rc-ch4  = &rc_ch4;
		rc-ch5  = &rc_ch5;
		rc-ch6  = &rc_ch6;
		gp8-out  = &gp8_out;
		gp9-out  = &gp9_out;
		gp10-out = &gp10_out;
		gp11-out = &gp11_out;
	};
};

&zephyr_udc0 {
	cdc_acm_uart0: cdc_acm_uart0 {
		compatible = "zephyr,cdc-acm-uart";
	};
};

&ethernet {
	compatible = "wiznet,w6100";
};

/* LittleFS storage partition — last 1MB of flash (offset 15MB) */
&flash0 {
	partitions {
		storage_partition: partition@f00000 {
			label = "storage";
			reg = <0x00f00000 0x00100000>;
		};
	};
};
